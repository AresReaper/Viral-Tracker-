{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The user's display name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "photoURL": {
          "type": "string",
          "format": "uri",
          "description": "The URL of the user's profile photo."
        },
        "role": {
          "type": "string",
          "enum": ["user", "admin"],
          "description": "The user's role."
        },
        "settings": {
          "type": "object",
          "properties": {
            "customApis": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": { "type": "string" },
                  "platform": { "type": "string" },
                  "apiKey": { "type": "string" },
                  "status": { "type": "string", "enum": ["untested", "working", "failed"] }
                },
                "required": ["id", "platform", "apiKey", "status"]
              }
            }
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time the user was created."
        }
      },
      "required": ["name", "email", "role", "createdAt"]
    },
    "Script": {
      "title": "Script",
      "description": "A generated viral script and metadata.",
      "type": "object",
      "properties": {
        "niche": {
          "type": "string",
          "description": "The niche or topic of the script."
        },
        "platform": {
          "type": "string",
          "enum": ["instagram", "youtube", "both"],
          "description": "The target platform."
        },
        "content": {
          "type": "string",
          "description": "The generated script content."
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Suggested tags for the video."
        },
        "tools": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "type": { "type": "string", "enum": ["free", "paid"] },
              "url": { "type": "string" },
              "description": { "type": "string" }
            },
            "required": ["name", "type", "url", "description"]
          },
          "description": "Suggested tools to create the video."
        },
        "watermarkTips": {
          "type": "string",
          "description": "Tips on removing watermarks from the suggested tools."
        },
        "imagePrompt": {
          "type": "string",
          "description": "A refined, high-quality image generation prompt for AI image tools."
        },
        "authorId": {
          "type": "string",
          "description": "The ID of the user who generated the script."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time the script was generated."
        }
      },
      "required": ["niche", "platform", "content", "tags", "tools", "watermarkTips", "imagePrompt", "authorId", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "scripts/{scriptId}": {
      "schema": { "$ref": "#/entities/Script" },
      "description": "Stores generated scripts."
    }
  }
}
